APP_NAME="Employee Project & Expense Management System"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# SQL Server configuration.
# Use either DATABASE_URL directly or the DB_* values below.
# The app uses synchronous SQLAlchemy Session, so DATABASE_URL should use mssql+pyodbc.
# DATABASE_URL="mssql+pyodbc:///?odbc_connect=DRIVER%3D%7BODBC+Driver+17+for+SQL+Server%7D%3BSERVER%3DBIFROST%5CSQLEXPRESS%3BDATABASE%3Demployee_management%3BTrusted_Connection%3Dyes%3BTrustServerCertificate%3Dyes"
DB_DRIVER="ODBC Driver 17 for SQL Server"
DB_SERVER="BIFROST\\SQLEXPRESS"
DB_NAME="employee_management"
DB_USER=""
DB_PASSWORD=""
DB_TRUST_SERVER_CERTIFICATE=true

JWT_SECRET_KEY="test_secret"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
FRONTEND_RESET_PASSWORD_URL="http://localhost:5173/reset-password"

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=[".pdf",".png",".jpg",".jpeg",".webp"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
LOG_LEVEL=INFO
