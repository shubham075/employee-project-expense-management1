APP_NAME="Employee Project & Expense Management System"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# SQL Server configuration.
# The app reads these via pydantic-settings from this .env file.
# Since DB_PASSWORD is empty, Windows Authentication is used with Trusted_Connection=yes.

DB_DRIVER=ODBC Driver 17 for SQL Server
DB_SERVER=LAPTOP-471
DB_NAME=employee_management
DB_USER=MPONLINE/26050050
DB_PASSWORD=
DB_TRUST_SERVER_CERTIFICATE=true

JWT_SECRET_KEY="test_key001"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
FRONTEND_RESET_PASSWORD_URL="http://localhost:5173/reset-password"

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=[".pdf",".png",".jpg",".jpeg",".webp"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
LOG_LEVEL=INFO
